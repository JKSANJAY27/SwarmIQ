# ── LLM: Local (Ollama) ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_AGENT_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── LLM: Cloud (Gemini, optional) ────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Memory: ChromaDB (local) ──────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_PREFIX=swarmiq_agent_

# ── Simulation ────────────────────────────────────────────────────
SIM_MAX_AGENTS=500
SIM_DEFAULT_TICKS=100
SIM_SNAPSHOT_INTERVAL=10
SIM_PARALLEL_WORKERS=8

# ── Storage ───────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/swarmiq.db
UPLOADS_DIR=./data/uploads
EXPORTS_DIR=./data/exports

# ── Server ────────────────────────────────────────────────────────
BACKEND_PORT=5001
FRONTEND_PORT=3000